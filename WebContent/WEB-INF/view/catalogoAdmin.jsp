<%@page import="model.ProdottoBean"%>
<%@ page language="java" contentType="text/html; charset=UTF-8" pageEncoding="UTF-8"%>
<!DOCTYPE html>
<html>
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<link rel="stylesheet" href="${pageContext.request.contextPath}/styles/style.css"/>
<link rel="stylesheet" href="${pageContext.request.contextPath}/styles/catalogoAdmin.css"/>
<title>GamesHub - CatalogoAmministratore</title>
</head>
<body>
<%@ include file="shared/header.jsp"%>

<% 
    java.util.List<ProdottoBean> catalogo = (java.util.List<ProdottoBean>) request.getAttribute("catalogo");
    if(catalogo == null || catalogo.size() == 0) { 
%>
    <div class="box-catalogo-vuoto">
        <h4>Il catalogo è vuoto</h4>
        <h5><a href="<%=request.getContextPath()%>/aggiungiProdotto">Clicca qui</a> per aggiungere un prodotto</h5>
    </div>
<% 
    } else { 
%>
    <div class="container-catalogo">
        <h3>Gestione Catalogo Prodotti</h3>
        
        <div class="azioni-top">
            <a href="<%=request.getContextPath()%>/aggiungiProdotto" class="btn-aggiungi">
                + Aggiungi Nuovo Prodotto
            </a>
        </div>

        <table class="tabella-prodotti">
            <thead>
                <tr>
                    <th>Nome</th>
                    <th>Tipologia</th>
                    <th>Genere</th>
                    <th>Piattaforma</th>
                    <th>Produttore</th>
                    <th>Prezzo</th>
                    <th>Disponibilità</th>
                    <th>Chiave</th>
                    <th>Azioni</th>
                </tr>
            </thead>
            <tbody>
                <% for(ProdottoBean prodotto : catalogo) { %>
                    <tr>
                        <td class="cella-nome"><strong><%= prodotto.getNome() %></strong></td>
                        <td><%= prodotto.getTipologia() %></td>
                        <td><%= prodotto.getGenere() != null ? prodotto.getGenere() : "-" %></td>
                        <td><%= prodotto.getPiattaforma() != null ? prodotto.getPiattaforma() : "-" %></td>
                        <td><%= prodotto.getCasaProduttrice() %></td>
                        <td>€ <%= String.format("%.2f", prodotto.getPrezzo()) %></td>
                        <td><%= prodotto.getDisponibilità() %></td>
                        <td><%= prodotto.getChiaveAttivazione() != null ? prodotto.getChiaveAttivazione() : "-" %></td>
                        <td class="container-azioni">
                        	<a class="azione azione-visualizza">
	                        	<svg xmlns="http://www.w3.org/2000/svg" fill="#000000" width="20px" height="20px" viewBox="0 0 32 32" version="1.1">
